{
  "name": "controle-financeiro-mensal",
  "version": "1.0.0",
  "private": true,
  "description": "Software desktop de controle financeiro mensal.",
  "author": "Controle Financeiro Mensal",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "mobile:build": "vite build",
    "mobile:preview": "vite preview --host 0.0.0.0",
    "preview": "vite preview --host 0.0.0.0",
    "desktop:dev": "electron .",
    "desktop:build": "node scripts/build-desktop.cjs",
    "desktop:publish": "node scripts/build-desktop.cjs --publish-github",
    "manual:pdf": "node scripts/create-manual-pdf.cjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "electron-updater": "^6.8.9",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^3.1.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "pdfkit": "^0.19.1"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "build": {
    "appId": "com.controlefinanceiromensal.app",
    "productName": "Controle Financeiro Mensal",
    "artifactName": "Controle-Financeiro-Mensal-${version}.${ext}",
    "directories": {
      "output": "outputs/desktop"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "portable": {
      "artifactName": "Controle-Financeiro-Mensal.exe"
    },
    "nsis": {
      "artifactName": "Instalador-Controle-Financeiro-Mensal.exe",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Controle Financeiro Mensal",
      "uninstallDisplayName": "Controle Financeiro Mensal"
    }
  }
}
